# ============================================
# Application
# ============================================
NODE_ENV=development
PORT=3000
API_VERSION=v1
APP_NAME="Enterprise Marketplace"
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ============================================
# Database
# ============================================
DATABASE_URL=postgresql://postgres:password@localhost:5432/marketplace_db
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10
DATABASE_LOG_LEVEL=warn

# ============================================
# Redis
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=marketplace:
REDIS_TLS=false

# ============================================
# JWT Authentication
# ============================================
# Generate with: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_EXPIRY=7d
JWT_ISSUER=enterprise-marketplace
JWT_AUDIENCE=marketplace-users

# ============================================
# Email (Nodemailer)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_NAME="Enterprise Marketplace"
SMTP_FROM_EMAIL=noreply@marketplace.com

# MailHog for development
# SMTP_HOST=localhost
# SMTP_PORT=1025

# ============================================
# Cloudinary (File Uploads)
# ============================================
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_FOLDER=marketplace

# ============================================
# Stripe (Payments)
# ============================================
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_CURRENCY=usd

# ============================================
# Security
# ============================================
BCRYPT_SALT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_DURATION_MINUTES=30
PASSWORD_RESET_TOKEN_EXPIRY_HOURS=1
EMAIL_VERIFICATION_TOKEN_EXPIRY_HOURS=24
SESSION_SECRET=super-secret-session-key-change-in-production

# ============================================
# Rate Limiting
# ============================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=10
UPLOAD_RATE_LIMIT_MAX=20

# ============================================
# BullMQ / Queue
# ============================================
QUEUE_EMAIL_CONCURRENCY=3
QUEUE_NOTIFICATION_CONCURRENCY=2
QUEUE_ORDER_CONCURRENCY=5
QUEUE_RETRY_ATTEMPTS=3
QUEUE_RETRY_DELAY_MS=5000

# ============================================
# Pagination Defaults
# ============================================
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# ============================================
# File Upload
# ============================================
MAX_FILE_SIZE_MB=5
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp,image/gif
MAX_IMAGES_PER_PRODUCT=10

# ============================================
# Firebase (Push Notifications - Optional)
# ============================================
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# ============================================
# Logging
# ============================================
LOG_LEVEL=info
LOG_FORMAT=json
LOG_FILE_PATH=logs/app.log
LOG_ERROR_FILE_PATH=logs/error.log
LOG_MAX_SIZE=10m
LOG_MAX_FILES=14d

# ============================================
# Platform Settings
# ============================================
DEFAULT_COMMISSION_RATE=10
PLATFORM_TAX_RATE=8
FREE_SHIPPING_THRESHOLD=50
CART_EXPIRY_DAYS=7
